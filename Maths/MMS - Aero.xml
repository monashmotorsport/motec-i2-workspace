<?xml version="1.0"?>
<Maths Locale="English_Australia.1252" DefaultLocale="C" Id="MMS - Aero">
 <MathConstants>
  <MathConstant Name="Air Density" Value="1.225" Unit="kg/m3"/>
  <MathConstant Name="CdA" Value="1.8" Unit="m2"/>
  <MathConstant Name="ClA" Value="5.4" Unit="m2"/>
 </MathConstants>
 <MathItems>
  <MathExpression Id="Dynamic Pressure" DisplayUnit="Pa" DisplayDPS="2" DisplayColorIndex="7" Interpolate="1" Script="0.5 * 'Air Density' [kg/m3] * sqr('Corr Speed' [m/s])" SampleRate="0" Unit="Pa"/>
  <MathExpression Id="Drag Force" DisplayUnit="N" DisplayDPS="2" DisplayColorIndex="6" Interpolate="1" Script="'Dynamic Pressure' [Pa] * 'CdA' [m2]" SampleRate="0" Unit="N"/>
  <MathExpression Id="Drag Power" DisplayUnit="kW" DisplayDPS="2" DisplayColorIndex="6" Interpolate="1" Script="'Corr Speed' [m/s] * 'Drag Force' [N]" SampleRate="0" Unit="W"/>
  <MathExpression Id="Lift Force" DisplayUnit="N" DisplayDPS="2" DisplayColorIndex="5" Interpolate="1" Script="'Dynamic Pressure' [Pa] * 'ClA' [m2]" SampleRate="0" Unit="N"/>
  <MathExpression Id="Lift Power" DisplayUnit="kW" DisplayDPS="2" DisplayColorIndex="5" Interpolate="1" Script="'Corr Speed' [m/s] * 'Lift Force' [N]" SampleRate="0" Unit="W"/>
 </MathItems>
</Maths>
